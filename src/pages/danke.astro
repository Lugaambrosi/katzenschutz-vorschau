---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Vielen Dank für deine Anfrage! – KatzenSchutz Miez</title>
<meta name="robots" content="noindex, follow" />
</head>
<body>

<nav>
  <span class="nav-brand">KatzenSchutz Miez</span>
</nav>

<main>
  <div class="success-icon">✓</div>
  <h1>Deine Anfrage ist angekommen!</h1>
  <p>Vielen Dank für dein Vertrauen. Ich habe deine Nachricht erhalten und melde mich schnellstmöglich persönlich bei dir.</p>

  <div class="info-box">
    <h3>So geht es weiter:</h3>
    <p>Ich prüfe deine Angaben und erstelle ein unverbindliches Angebot, das optimal zu deiner Katze passt. Die Rückmeldung erfolgt meist innerhalb weniger Stunden.</p>
  </div>

  <div class="btn-container">
    <a class="btn-wa" href="https://wa.me/4917679552698" target="_blank" rel="noopener">Gleich per WhatsApp kontaktieren</a>
    <a class="btn-primary" href={base}>Zurück zur Startseite</a>
  </div>
</main>

<footer>
  <p style="margin-bottom:.5rem">&copy; 2026 KatzenSchutz Miez · Luca Ambos</p>
  <a href={base + 'impressum.html'}>Impressum</a> · <a href={base + 'datenschutz.html'}>Datenschutz</a> · <a href="#" class="ksm-cookie-settings">Cookie-Einstellungen</a>
</footer>

<script is:inline src={base + 'consent.js?v=3'} defer></script>
<script is:inline>
/* Conversion auf der Danke-Seite: feuert, sobald (nach Zustimmung) GA bzw. Meta geladen ist. */
(function () {
  var sentGA = false, sentFB = false, n = 0;
  var t = setInterval(function () {
    if (window.gtag && !sentGA) { sentGA = true; window.gtag('event', 'qualify_lead', { value: 1, currency: 'EUR' }); }
    if (window.fbq && !sentFB) { sentFB = true; window.fbq('track', 'Lead'); }
    if ((sentGA && sentFB) || ++n > 40) clearInterval(t);
  }, 250);
})();
</script>

<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#fff;background:#002641;line-height:1.7;min-height:100vh;display:flex;flex-direction:column;justify-content:space-between}
a{text-decoration:none}
nav{background:rgba(18,16,31,.96);padding:.8rem 1.5rem;display:flex;align-items:center;justify-content:center;border-bottom:1px solid rgba(255,255,255,.05)}
.nav-brand{color:#fff;font-weight:800;font-size:1.1rem}
main{max-width:600px;margin:auto;padding:3rem 1.5rem;text-align:center;width:100%}
.success-icon{font-size:4.5rem;margin-bottom:1.5rem;animation:bounce 2s infinite}
h1{font-size:clamp(1.8rem,4vw,2.5rem);font-weight:900;color:#fff;margin-bottom:1.2rem;line-height:1.2}
p{font-size:1.05rem;color:rgba(255,255,255,.8);margin-bottom:2rem}
.info-box{background:rgba(255,255,255,.04);border:1px solid rgba(167,139,250,.2);border-radius:18px;padding:1.6rem;margin-bottom:2.2rem}
.info-box h3{font-size:1.05rem;font-weight:800;color:#babaff;margin-bottom:.5rem}
.info-box p{font-size:.9rem;color:rgba(255,255,255,.7);margin-bottom:0}
.btn-container{display:flex;flex-direction:column;gap:.9rem}
.btn-primary{background:#0071b2;color:#fff;padding:1rem 2.2rem;border-radius:30px;font-weight:800;font-size:1rem;display:inline-block;box-shadow:0 8px 24px rgba(0,113,178,.45);transition:background .2s}
.btn-primary:hover{background:#005a8f}
.btn-wa{background:#25d366;color:#fff;padding:1rem 2.2rem;border-radius:30px;font-weight:800;font-size:1rem;display:inline-flex;align-items:center;justify-content:center;gap:.5rem;box-shadow:0 8px 24px rgba(37,211,102,.3);transition:background .2s}
.btn-wa:hover{background:#20ba5a}
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}
footer{background:#001320;color:rgba(255,255,255,.45);padding:2rem 1.5rem;text-align:center;font-size:.78rem}
footer a{color:rgba(255,255,255,.6);margin:0 .7rem}
footer a:hover{color:#fff}
</style>
</body>
</html>
