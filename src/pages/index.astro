        animation: reviewScroll 60s linear infinite;
      }
      .review-marquee-row.rev {
        animation-direction: reverse;
      }
      .review-marquee:hover .review-marquee-row {
        animation-play-state: paused;
      }
      @keyframes reviewScroll {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .review-marquee {
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: center;
        }
        .review-marquee-row {
          animation: none;
          width: auto;
          flex-wrap: wrap;
          justify-content: center;
        }
        .review-marquee-row.rev {
          display: none;
        }
      }
      .review-card {
        display: flex;
        flex-direction: column;
        min-width: 300px;
        max-width: 300px;
        min-height: 250px;
        margin-right: 1.5rem;
        background: #fff;
        border: 1px solid #e3ebf2;
        border-radius: 18px;
        padding: 1.6rem;
        box-shadow: 0 6px 20px rgba(26, 26, 46, 0.07);
      }
      .review-quote {
        width: 40px;
        height: 40px;
        color: #0071b2;
        margin-bottom: 0.5rem;
      }
      .review-card .stars {
        color: #f97316;
        font-size: 0.95rem;
        margin-bottom: 0.7rem;
      }
      .review-card p {
        font-size: 0.86rem;
        color: #555;
        line-height: 1.6;
        margin-bottom: 1.2rem;
      }
      .review-author {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        margin-top: auto;
      }
      .review-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
        flex-shrink: 0;
      }
      .review-name {
        font-weight: 700;
        color: #002641;
        font-size: 0.9rem;
        line-height: 1.2;
      }
      .review-source {
        font-size: 0.78rem;
        color: #888;
      }
      .review-cta {
        text-align: center;
        margin-top: 1.6rem;
      }
      .review-cta .btn-primary {
        display: inline-block;
        background: #0071b2;
        color: #fff;
        padding: 1rem 2.2rem;
        border-radius: 30px;
        font-weight: 800;
        font-size: 1rem;
        box-shadow: 0 8px 24px rgba(0, 113, 178, 0.45);
      }
      .review-cta .btn-primary:hover {
        background: #005a8f;
      }

      /* ABLAUF */
      .steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        max-width: 920px;
        margin: 0 auto;
      }
      .step {
        text-align: center;
        padding: 1.2rem 0.8rem;
      }
      .step .num {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #0071b2;
        color: #fff;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.7rem;
        font-size: 1.05rem;
      }
      .step h3 {
        font-size: 0.9rem;
        font-weight: 800;
        margin-bottom: 0.3rem;
      }
      .step p {
        font-size: 0.78rem;
        color: #777;
        line-height: 1.5;
      }

      /* FAQ */
      #faq {
        background: #f2f7fb;
      }
      .faq-list {
        max-width: 740px;
        margin: 0 auto;
      }
      details {
        background: #fff;
        border: 1px solid #e3ebf2;
        border-radius: 14px;
        margin-bottom: 0.8rem;
        overflow: hidden;
      }
      summary {
        cursor: pointer;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 1.1rem 3rem 1.1rem 1.3rem;
        list-style: none;
        position: relative;
        color: #002641;
      }
      summary::-webkit-details-marker {
        display: none;
      }
      summary::after {
        content: "+";
        position: absolute;
        right: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.4rem;
        font-weight: 400;
        color: #0071b2;
        transition: transform 0.2s;
      }
      details[open] summary::after {
        transform: translateY(-50%) rotate(45deg);
      }
      .faq-a {
        padding: 0 1.3rem 1.2rem;
        font-size: 0.89rem;
        color: #555;
        line-height: 1.7;
      }

      /* FORMULAR */
      #kontakt {
        background: #002641;
      }
      #kontakt .section-label {
        color: #babaff;
      }
      #kontakt h2 {
        color: #fff;
      }
      #kontakt .section-sub {
        color: rgba(255, 255, 255, 0.7);
      }
      form {
        max-width: 660px;
        margin: 0 auto;
        background: #fff;
        border-radius: 20px;
        padding: 2.2rem;
      }
      .form-block {
        margin-bottom: 1.4rem;
      }
      .form-block-title {
        font-size: 0.7rem;
        font-weight: 800;
        color: #0071b2;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: 0.8rem;
      }
      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.9rem;
      }
      @media (max-width: 560px) {
        .form-row {
          grid-template-columns: 1fr;
        }
      }
      label {
        display: block;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
        color: #333;
      }
      input,
      select,
      textarea {
        width: 100%;
        padding: 0.72rem 0.9rem;
        border: 1px solid #ddd;
        border-radius: 10px;
        font-size: 0.9rem;
        font-family: inherit;
        margin-bottom: 0.9rem;
        background: #fff;
        color: #002641;
      }
      input:focus,
      select:focus,
      textarea:focus {
        outline: 2px solid #0071b2;
        border-color: transparent;
      }
      button[type="submit"] {
        width: 100%;
        background: #0071b2;
        color: #fff;
        border: none;
        padding: 1.05rem;
        border-radius: 30px;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
      }
      button[type="submit"]:hover {
        background: #005a8f;
      }
      .form-note {
        font-size: 0.75rem;
        color: #888;
        text-align: center;
        margin-top: 0.8rem;
      }

      /* FOOTER */
      footer {
        background: #001320;
        color: rgba(255, 255, 255, 0.65);
        padding: 2.6rem 1.5rem;
        text-align: center;
        font-size: 0.82rem;
      }
      .footer-links {
        display: flex;
        gap: 1.4rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 1.4rem;
      }
      .footer-links a {
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
      }
      .footer-links a:hover {
        color: #fff;
      }
      footer .legal {
        max-width: 660px;
        margin: 0 auto;
        line-height: 1.7;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.45);
      }

      /* WHATSAPP BUBBLE */
      .wa-bubble {
        position: fixed;
        bottom: 1.4rem;
        right: 1.4rem;
        z-index: 200;
        background: #25d366;
        color: #fff;
        font-weight: 800;
        font-size: 0.88rem;
        padding: 0.85rem 1.3rem;
        border-radius: 30px;
        box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
    </style>
  </body>
</html>
