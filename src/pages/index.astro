    <!-- Formular-Versand (AJAX) + Weiterleitung zur Danke-Seite -->
    <script is:inline define:vars={{ dankeUrl }}>
      (function () {
        var form = document.getElementById("ksm-form");
        if (!form) return;
        var btn = form.querySelector("button[type=submit]");
        var label = btn ? btn.textContent : "";
        form.addEventListener("submit", async function (e) {
          e.preventDefault();
          if (btn) {
            btn.disabled = true;
            btn.textContent = "Wird gesendet …";
          }
          try {
            var res = await fetch(form.action, {
              method: "POST",
              body: new FormData(form),
              headers: { Accept: "application/json" },
            });
            if (res.ok) {
              window.location.href = dankeUrl;
              return;
            }
            throw new Error("bad status");
          } catch (err) {
            alert(
              "Es gab ein Problem beim Senden. Bitte versuch es erneut oder melde dich gern per WhatsApp."
            );
            if (btn) {
              btn.disabled = false;
              btn.textContent = label;
            }
          }
        });
      })();
    </script>

