---
import "@/styles/globals.css";
import { Hero } from "@/components/ui/animated-hero";
import SocialCards from "@/components/ui/card-fan-carousel";
import CostCalculator from "@/components/ui/cost-calculator";

const base = import.meta.env.BASE_URL;
const dankeUrl = `${import.meta.env.SITE}${base}danke.html`;
const barmeniaKV =
  "https://ssl.barmenia.de/online-versichern/#/tierversicherung/Beitrag?tierart=Katze&versicherung=kv&adm=00011802";
const barmeniaOP =
  "https://ssl.barmenia.de/online-versichern/#/tierversicherung/Beitrag?tierart=Katze&versicherung=op&adm=00011802";

const catCards = [
  {
    imgUrl: "https://katzenschutz-miez.de/katz_jung.jpg",
    alt: "Junge Katze",
    title: "Junge Katze, Fremdkörper verschluckt",
    text: "Kitten erkunden alles mit dem Maul. Eine Not-OP wegen verschlucktem Spielzeug ist einer der häufigsten Eingriffe bei jungen Katzen. OP-Kosten: ca. 1.500–2.500 €.",
  },
  {
    imgUrl: "https://katzenschutz-miez.de/katz_3.jpg",
    alt: "Freigänger-Katze",
    title: "Freigänger nach Unfall",
    text: "Autounfall, Bissverletzung, Sturz: Freigänger leben gefährlicher. Bei Unfällen gilt in der Krankenversicherung keine Wartezeit. Behandlung: ca. 2.000–4.000 €.",
  },
  {
    imgUrl: "https://katzenschutz-miez.de/katz_hero.jpg",
    alt: "Weiße Katze",
    title: "Nie wieder Angst vor der Tierarztrechnung",
    text: "Katzenkrankenversicherung mit persönlicher Beratung von Luca Ambos – persönlich und ehrlich, statt anonymer Hotline.",
  },
  {
    imgUrl: "https://katzenschutz-miez.de/katz_luca.jpg",
    alt: "Luca mit Katze",
    title: "Dein persönlicher Ansprechpartner",
    text: "Hi, ich bin Luca aus Berlin. Keine Hotline, kein Callcenter – du sprichst direkt mit mir, vor und nach dem Abschluss.",
  },
  {
    imgUrl: "https://katzenschutz-miez.de/katz_postop.jpg",
    alt: "Katze nach der OP",
    title: "Nachsorge nach der OP",
    text: "Mit der OP ist es selten getan: Nachbehandlungen, Medikamente und Kontrollen sind je nach Tarif bis zu 120 Tage nach der OP mitversichert. Nachsorge: oft mehrere hundert €.",
  },
  {
    imgUrl: "https://katzenschutz-miez.de/katz_parallax.jpg",
    alt: "Katze auf dem Sofa",
    title: "EisbaumTabelle Testsieger 2026",
    text: "Die Barmenia Premium Plus zählt zu den Top-Tarifen: 100 % Erstattung bis zum 3-fachen GOT-Satz, im Notdienst sogar bis zum 4-fachen – und Operationen ganz ohne Jahreshöchstgrenze.",
  },
];

const reviews = [
  {
    name: "Niklas K.",
    text: "Ich bin absolut begeistert von der Beratung und dem Service bei Luca! Als ich auf der Suche nach einer neuen Versicherung war, hat mir Luca kompetent und verständlich alle Optionen erklärt …",
  },
  {
    name: "Oleg R.",
    text: "Luca is extremely professional in everything what comes to insurance and helped me and my family a lot! Highly recommend to get in touch and work with him! Much respect!",
  },
  {
    name: "Brun G.",
    text: "Nothing but positive to say. Mr Ambos is willing to help in any circumstance and in a prompt manner. He has been of great advice up until now and definitely deserves the praise.",
  },
  {
    name: "Google-Nutzer",
    text: "Auch die Bearbeitung meiner Anfragen ging immer schnell und unkompliziert.",
  },
  {
    name: "Google-Nutzer",
    text: "Großes Lob und Weiterempfehlung!",
  },
];

const avatarColors = ["#0071b2", "#16a34a", "#e11d48", "#f59e0b", "#8b5cf6"];
function reviewInitials(name: string) {
  if (name.startsWith("Google")) return "G";
  const p = name.trim().split(/\s+/);
  return ((p[0]?.[0] ?? "") + (p[1]?.[0] ?? "")).toUpperCase();
}
const reviewsFull = reviews.map((r, i) => ({
  ...r,
  initials: reviewInitials(r.name),
  color: avatarColors[i % avatarColors.length],
  source: "Google-Rezension",
}));
// Dupliziert für nahtloses Endlos-Scrollen; zweite Reihe umgekehrt.
const reviewsRow1 = [...reviewsFull, ...reviewsFull];
const reviewsRow2 = [...[...reviewsFull].reverse(), ...[...reviewsFull].reverse()];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KatzenSchutz Miez – Katzenkrankenversicherung mit Luca Ambos</title>
    <meta
      name="description"
      content="Katzenkrankenversicherung und Katzen-OP-Schutz der BarmeniaGothaer ab 14,84 €/Monat. Persönliche Beratung durch Luca Ambos, Berlin. EisbaumTabelle Testsieger 2026."
    />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <a class="nav-brand" href="#hero">KatzenSchutz Miez</a>
      <div class="nav-links">
        <a href="#kosten">Tierarztkosten</a>
        <a href="#leistungen">Leistungen</a>
        <a href="#vergleich">Tarife</a>
        <a href="#ueber">Über mich</a>
        <a href="#reviews">Bewertungen</a>
        <a href="#faq">FAQ</a>
      </div>
      <a class="btn-nav" href="#kontakt">Kostenlose Beratung</a>
    </nav>

    <main>
      <div id="hero">
        <Hero client:load />
      </div>

      <!-- TESTSIEGER-BAND (EisbaumTabelle, prominent) -->
      <section id="testsieger" class="testsieger">
        <div class="container">
          <div class="ts-grid">
            <div class="ts-main">
              <div class="ts-trophy">🏆</div>
              <div>
                <div class="ts-kicker">EisbaumTabelle 2026 · Platz 1</div>
                <h2 class="ts-h">Testsieger Katzenkrankenversicherung</h2>
                <p class="ts-sub">
                  Die <strong>Barmenia Premium Plus</strong> steht bei der unabhängigen
                  EisbaumTabelle 2026 mit <strong>98 % Ø-Erstattung</strong> auf Platz 1 –
                  und genau diesen Tarif empfehle ich dir.
                </p>
                <a
                  class="ts-link"
                  href="https://www.eisbaumtabelle.de/katze"
                  target="_blank"
                  rel="noopener">Testsieger ansehen →</a
                >
              </div>
            </div>
            <div class="ts-side">
              <div class="ts-item">
                <span class="ts-stars">★★★★★</span>
                <div>
                  <div class="ts-big">5,0 bei Google</div>
                  <a
                    href="https://g.page/r/CZ_BYAxxpUq7EBM/review"
                    target="_blank"
                    rel="noopener">Bewertung schreiben</a
                  >
                </div>
              </div>
              <div class="ts-item">
                <span class="ts-emoji">🐾</span>
                <div>
                  <div class="ts-big">Mit Katzen aufgewachsen</div>
                  <span class="ts-muted">Ich kenne das Thema aus der Familie</span>
                </div>
              </div>
              <div class="ts-item ts-logo">
                <img
                  src="https://cdn.barmeniagothaer.de/barmeniagothaer/media/barmeniagothaer_logo_white-original_webp.webp"
                  alt="BarmeniaGothaer Logo"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
          <p class="ts-pruef">
            Außerdem von <strong>Stiftung Warentest</strong> geprüft (Finanztest
            02/2026): unbegrenzte Versicherungssumme und Erstattung bis zum
            4-fachen GOT-Satz.
          </p>
        </div>
      </section>

      <!-- WARUM JETZT / TIERARZTKOSTEN -->
      <section id="kosten">
        <div class="container">
          <div class="section-label">Warum jetzt?</div>
          <h2>Tierarztkosten steigen – dein Risiko auch</h2>
          <p class="section-sub">
            Seit der neuen Gebührenordnung für Tierärzte (GOT) rechnen Praxen bis zum
            4-fachen Satz ab – im Notdienst sogar verpflichtend erhöht. Eine einzige
            Behandlung kann vierstellig werden.
          </p>
          <div class="cards-3">
            <div class="card">
              <h3>Standard-Schutz reicht oft nicht</h3>
              <p>
                Viele Tarife erstatten nur 60–80 % oder deckeln die Jahresleistung. Der
                Rest bleibt an dir hängen – ausgerechnet im Ernstfall.
              </p>
            </div>
            <div class="card">
              <h3>Zähne &amp; Rasse-Erkrankungen</h3>
              <p>
                FORL, Wurzelbehandlungen oder rassetypische Erkrankungen schließen viele
                Versicherer aus. In meinem empfohlenen Tarif sind sie mitversichert.
              </p>
            </div>
            <div class="card">
              <h3>Früh abschließen lohnt sich</h3>
              <p>
                Je jünger und gesünder deine Katze beim Abschluss ist, desto günstiger der
                Beitrag – und Vorerkrankungen sind noch kein Thema.
              </p>
            </div>
          </div>
          <div class="kosten-tabelle">
            <h3>Typische Behandlungskosten bei Katzen</h3>
            <div class="kosten-row">
              <span class="kr-name">Not-OP nach verschlucktem Fremdkörper</span><span
                class="kr-preis">1.500 – 2.500 €</span
              >
            </div>
            <div class="kosten-row">
              <span class="kr-name">Behandlung nach Autounfall (Freigänger)</span><span
                class="kr-preis">2.000 – 4.000 €</span
              >
            </div>
            <div class="kosten-row">
              <span class="kr-name">Zahnsanierung / FORL unter Vollnarkose</span><span
                class="kr-preis">800 – 1.500 €</span
              >
            </div>
            <div class="kosten-row">
              <span class="kr-name">Tumor-OP inkl. Diagnostik (MRT/CT)</span><span
                class="kr-preis">1.500 – 3.500 €</span
              >
            </div>
            <div class="kosten-row">
              <span class="kr-name">Nachsorge: Medikamente, Kontrollen, Klinik</span><span
                class="kr-preis">oft mehrere hundert €</span
              >
            </div>
            <p class="kosten-fussnote">
              Richtwerte je nach Praxis, Region und Gebührensatz (1- bis 4-fach nach GOT).
              Vor- und Nachbehandlungen kommen häufig hinzu.
            </p>
          </div>
        </div>
      </section>

      <!-- LEISTUNGEN -->
      <section id="leistungen">
        <div class="container">
          <div class="section-label">Das steckt drin</div>
          <h2>Starke Leistungen für deine Katze</h2>
          <p class="section-sub">
            Die Barmenia Premium Plus steht bei der <a
              href="https://www.eisbaumtabelle.de/katze"
              target="_blank"
              rel="noopener">EisbaumTabelle 2026</a
            > mit 98 % Ø-Erstattung auf Platz 1 – und das bekommst du dazu.
          </p>
          <div class="leistungen-grid">
            <div class="leistung-block">
              <h3>Versicherte Leistungen</h3>
              <ul>
                <li>
                  <strong>Unbegrenzte Leistungssumme</strong> – keine Jahres-Deckelung bei OPs
                </li>
                <li>
                  Erstattung bis zum <strong
                    >4-fachen Satz der Tierarzt-Gebührenordnung (GOT)</strong
                  >
                </li>
                <li>
                  <strong>Zahnerkrankungen</strong> inkl. FORL, Extraktionen &amp; Wurzelbehandlungen
                </li>
                <li><strong>Rassespezifische Erkrankungen</strong> – auch mehrfach</li>
                <li>Diagnostik wie <strong>MRT, CT, Röntgen</strong> vor der OP</li>
                <li><strong>Nachbehandlungen bis 30 Tage</strong> nach der OP</li>
                <li>Keine Wartezeit bei <strong>Unfällen &amp; Vergiftungen</strong></li>
              </ul>
            </div>
            <div class="leistung-block hell">
              <h3>Dein Plus bei mir</h3>
              <ul>
                <li>
                  <strong>Persönlicher Ansprechpartner</strong> – vor und nach dem Abschluss
                </li>
                <li>
                  <strong>Freie Tierarzt- und Klinikwahl</strong> in ganz Deutschland
                </li>
                <li>
                  <strong>Weltweiter Schutz</strong> bei Auslandsaufenthalten bis 12 Monate
                </li>
                <li>
                  Ehrliche Einschätzung: <strong>KV oder OP-Schutz</strong> – was wirklich passt
                </li>
                <li>Hilfe bei <strong>Erstattungen &amp; Rechnungen</strong> im Leistungsfall</li>
                <li>Erreichbar per <strong>WhatsApp, Telefon oder E-Mail</strong></li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- KOSTENRECHNER (interaktiv) -->
      <CostCalculator client:load />

      <!-- VERGLEICH -->
      <section id="vergleich">
        <div class="container">
          <div class="section-label">KV oder OP-Schutz?</div>
          <h2>Welcher Schutz passt zu deiner Katze?</h2>
          <p class="section-sub">
            Beide Varianten bieten echten Schutz – die richtige Wahl hängt von deiner
            Katze, deinem Budget und deinem Sicherheitsbedürfnis ab.
          </p>
          <div class="vergleich-grid">
            <div class="plan empfohlen">
              <div class="plan-tag">Empfohlen · Premium-Plus-Tarif</div>
              <h3>Katzenkrankenversicherung</h3>
              <div class="preis-sub">Schon ab</div>
              <div class="preis">14,84 € <span>/Monat</span></div>
              <div class="preis-sub">inkl. 20 % Selbstbeteiligung (max. 250 €)</div>
              <ul>
                <li>Unbegrenzte Leistungssumme</li>
                <li>Bis zum 4-fachen Tierarzt-Gebührensatz (GOT)</li>
                <li>Keine Wartezeit bei Unfällen</li>
                <li>Zahnextraktionen &amp; Wurzelbehandlungen</li>
                <li>Nachbehandlungen bis 30 Tage nach OP</li>
              </ul>
              <a class="btn-primary" href={barmeniaKV} target="_blank" rel="noopener"
                >Jetzt abschließen</a
              >
            </div>
            <div class="plan">
              <h3>Katzen-OP-Schutz</h3>
              <div class="preis-sub">Günstiger Einstieg</div>
              <div class="preis" style="font-size:1.45rem;padding:.45rem 0">
                Operationsschutz
              </div>
              <div class="preis-sub">Fokus auf Operationskosten</div>
              <ul>
                <li>Absicherung von Operationskosten</li>
                <li>Narkose und stationäre OP-Behandlung</li>
                <li>Günstigerer Monatsbeitrag</li>
                <li>Sinnvoll für junge, gesunde Katzen</li>
              </ul>
              <a class="btn-outline" href={barmeniaOP} target="_blank" rel="noopener"
                >Beitrag berechnen</a
              >
            </div>
          </div>
          <div class="hinweis">
            Bekannte Vorerkrankungen und bereits angeratene Behandlungen müssen beim Antrag
            vollständig angegeben werden. Bei Unsicherheiten – melde dich bei mir.
          </div>
        </div>
      </section>

      <!-- ÜBER MICH -->
      <section id="ueber">
        <div class="container">
          <div class="section-label">Über mich</div>
          <h2>Dein persönlicher Ansprechpartner</h2>
          <p class="section-sub" style="color:rgba(255,255,255,.7)">
            Keine Hotline, kein Callcenter – du sprichst direkt mit mir.
          </p>
          <div class="ueber-grid">
            <img src="https://katzenschutz-miez.de/katz_luca.jpg" alt="Luca Ambos mit Katze" />
            <div class="ueber-text">
              <p>
                Hi, ich bin <strong>Luca</strong>. Ich bin mit Katzen groß geworden. Bei uns
                zu Hause lebten zwei, Emmi und Josie, und sie gehörten ganz
                selbstverständlich zur Familie. Eine eigene Katze habe ich gerade nicht,
                aber in der Familie sind immer welche dabei, und bei meiner Mutter wohnt
                inzwischen ein Hund. Für mich ist klar: So ein Tier ist ein
                Familienmitglied, und dass es ihm gut geht, zählt genauso wie bei allen
                anderen.
              </p>
              <p>
                Wer eine Freigängerkatze hat, kennt das: Irgendwann liegt die erste tote
                Maus vor der Tür, stolz vorbeigebracht, und die Begeisterung in der Familie
                hält sich in Grenzen. Genau da merkt man aber, wie viel diese kleinen
                Mitbewohner draußen erleben und wie schnell mal etwas passieren kann.
                Freigänger brauchen einen besonderen Blick, und seinen Liebsten will man
                eben das Beste geben.
              </p>
              <p>
                Genau deswegen setze ich mich <strong>für dich</strong> ein: Ich erkläre dir
                verständlich, was versichert ist und was nicht, helfe bei der Tarifwahl und
                bleibe auch <strong>nach dem Abschluss</strong> dein Ansprechpartner, ob bei
                Fragen zur Erstattung oder zu Rechnungen. Die Beratung ist <strong
                  >kostenlos und unverbindlich</strong
                >, per Telefon, WhatsApp oder E-Mail.
              </p>
              <div class="ueber-ctas">
                <a
                  class="btn-wa"
                  href="https://wa.me/4917679552698"
                  target="_blank"
                  rel="noopener">WhatsApp schreiben</a
                >
                <a class="btn-mail" href="mailto:ambos.luca@gmail.com">E-Mail senden</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SZENARIEN (interaktives Karten-Karussell) -->
      <section id="szenarien" class="szenarien">
        <div class="container">
          <div class="section-label">Aus der Praxis</div>
          <h2>Echte Fellnasen, echt abgesichert</h2>
          <p class="section-sub">Klick auf eine Karte für die ganze Geschichte.</p>
        </div>
        <SocialCards client:load cards={catCards} />
      </section>

      <!-- REVIEWS -->
      <section id="reviews">
        <div class="container">
          <div class="section-label">Google Bewertungen</div>
          <div class="review-head">
            <div class="score">5,0</div>
            <div class="stars">★★★★★</div>
          </div>
          <div class="review-marquee">
            <div class="review-marquee-row">
              {
                reviewsRow1.map((r) => (
                  <div class="review-card">
                    <svg class="review-quote" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M7.17 6C4.9 6 3 7.9 3 10.17c0 2.2 1.72 3.98 3.9 4.08-.13 1.2-.9 2.3-2.06 2.9-.3.16-.42.5-.28.8.14.3.5.44.8.3C10.2 16.9 11 13.6 11 10.6V10c0-2.2-1.8-4-3.83-4zm10 0C15.9 6 14 7.9 14 10.17c0 2.2 1.72 3.98 3.9 4.08-.13 1.2-.9 2.3-2.06 2.9-.3.16-.42.5-.28.8.14.3.5.44.8.3C20.2 16.9 21 13.6 21 10.6V10c0-2.2-1.8-4-3.83-4z" />
                    </svg>
                    <div class="stars">★★★★★</div>
                    <p>{r.text}</p>
                    <div class="review-author">
                      <div class="review-avatar" style={`background:${r.color}`}>{r.initials}</div>
                      <div>
                        <div class="review-name">{r.name}</div>
                        <div class="review-source">{r.source}</div>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="review-marquee-row rev">
              {
                reviewsRow2.map((r) => (
                  <div class="review-card">
                    <svg class="review-quote" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M7.17 6C4.9 6 3 7.9 3 10.17c0 2.2 1.72 3.98 3.9 4.08-.13 1.2-.9 2.3-2.06 2.9-.3.16-.42.5-.28.8.14.3.5.44.8.3C10.2 16.9 11 13.6 11 10.6V10c0-2.2-1.8-4-3.83-4zm10 0C15.9 6 14 7.9 14 10.17c0 2.2 1.72 3.98 3.9 4.08-.13 1.2-.9 2.3-2.06 2.9-.3.16-.42.5-.28.8.14.3.5.44.8.3C20.2 16.9 21 13.6 21 10.6V10c0-2.2-1.8-4-3.83-4z" />
                    </svg>
                    <div class="stars">★★★★★</div>
                    <p>{r.text}</p>
                    <div class="review-author">
                      <div class="review-avatar" style={`background:${r.color}`}>{r.initials}</div>
                      <div>
                        <div class="review-name">{r.name}</div>
                        <div class="review-source">{r.source}</div>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="review-cta">
            <a
              class="btn-primary"
              href="https://g.page/r/CZ_BYAxxpUq7EBM/review"
              target="_blank"
              rel="noopener">Jetzt Bewertung schreiben</a
            >
          </div>
        </div>
      </section>

      <!-- ABLAUF -->
      <section id="ablauf">
        <div class="container">
          <div class="section-label">So läuft es ab</div>
          <h2>In 6 Schritten zur Absicherung</h2>
          <p class="section-sub">
            Vom ersten Kontakt bis zum fertigen Schutz – einfach und transparent.
          </p>
          <div class="steps">
            <div class="step">
              <div class="num">1</div>
              <h3>Anfrage stellen</h3>
              <p>Kurzes Formular, 3 Minuten</p>
            </div>
            <div class="step">
              <div class="num">2</div>
              <h3>Katzendaten</h3>
              <p>Rasse, Alter, Gesundheit</p>
            </div>
            <div class="step">
              <div class="num">3</div>
              <h3>Einschätzung</h3>
              <p>Persönliche Empfehlung</p>
            </div>
            <div class="step">
              <div class="num">4</div>
              <h3>Schutz wählen</h3>
              <p>KV oder OP</p>
            </div>
            <div class="step">
              <div class="num">5</div>
              <h3>Online abschließen</h3>
              <p>Direkt über meinen Link</p>
            </div>
            <div class="step">
              <div class="num">6</div>
              <h3>Weiter begleitet</h3>
              <p>Ich bin weiter für dich da</p>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq">
        <div class="container">
          <div class="section-label">FAQ</div>
          <h2>Häufige Fragen</h2>
          <p class="section-sub">
            Die wichtigsten Antworten auf einen Blick – alles Weitere klären wir
            persönlich.
          </p>
          <div class="faq-list">
            <details>
              <summary>Was ist der Unterschied zwischen Krankenversicherung und OP-Schutz?</summary>
              <div class="faq-a">
                Der OP-Schutz greift bei chirurgischen Eingriffen inkl. Narkose und
                stationärer Behandlung. Die Krankenversicherung (Vollschutz) deckt darüber
                hinaus auch ambulante Behandlungen, Diagnostik, Medikamente und
                Zahnbehandlungen ab – und ist der Tarif, der bei der EisbaumTabelle 2026 auf
                Platz 1 steht.
              </div>
            </details>
            <details>
